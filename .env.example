# Copy this file to .env and fill in your real credentials.
# .env is never committed — it lives only on your machine.

TV_USERNAME=your_tradingview_email@example.com
TV_PASSWORD=your_tradingview_password

# Password for the web UI when accessed via ngrok (leave blank for local-only use)
UI_PASSWORD=!TraderMillionnaire12345

# Gmail App Password for URL email notifications (NOT your regular Gmail password)
# Create at: myaccount.google.com → Security → 2-Step Verification → App passwords
# Select Mail + Windows Computer → paste the 16 chars here WITHOUT spaces
GMAIL_APP_PASSWORD=abcdefghijklmnop
